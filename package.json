{
  "name": "consumer-pipeline",
  "version": "1.1.0",
  "description": "Pub/Sub consumer pipeline — ChromaDB, ClickHouse, Wikipedia, Graph, Skill Updater, Eval",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "consumer:chromadb": "node src/consumers/chromadb/index.js",
    "consumer:clickhouse": "node src/consumers/clickhouse/index.js",
    "consumer:wikipedia": "node src/consumers/wikipedia/index.js",
    "consumer:graph": "node src/consumers/graph/index.js",
    "consumer:skill-updater": "node src/consumers/skill-updater/index.js",
    "consumer:eval": "node src/consumers/eval/index.js",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "infra:reset": "docker compose down -v && docker compose up -d",
    "docker:build": "docker build -t gcr.io/blobfish-ai-429200/consumer-pipeline:latest .",
    "docker:push": "docker push gcr.io/blobfish-ai-429200/consumer-pipeline:latest",
    "k8s:deploy": "kubectl apply -f k8s/base/namespace.yaml && kubectl apply -f k8s/base/secrets.yaml && kubectl apply -f k8s/base/configmap.yaml && kubectl apply -f k8s/data-stores/ && kubectl apply -f k8s/base/consumers.yaml",
    "serve": "node src/server.js",
    "pipeline": "node scripts/pipeline-run.js",
    "pipeline:dry": "node scripts/pipeline-run.js --dry-run",
    "pipeline:skip-ingest": "node scripts/pipeline-run.js --skip-ingest",
    "research": "node src/research-agent/index.js",
    "research:dry": "node src/research-agent/index.js --dry-run --limit 1",
    "connectors": "node src/connectors/index.js",
    "eval-gate": "node src/eval-gate/index.js",
    "promote": "node src/promote/index.js",
    "flywheel": "node src/flywheel.js",
    "deploy": "bash scripts/deploy.sh",
    "status": "kubectl -n consumer-pipeline get pods,svc,pvc"
  },
  "dependencies": {
    "@clickhouse/client": "^1.8.1",
    "@google-cloud/pubsub": "^5.3.0",
    "glob": "^10.3.10",
    "js-yaml": "^4.1.0",
    "neo4j-driver": "^5.27.0",
    "winston": "^3.11.0"
  },
  "engines": {
    "node": ">=18"
  }
}
